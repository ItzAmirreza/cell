# Example Cellfile — the declarative container format for Cell.
#
# Build: cell build Cellfile.example
# Run:   cell run hello

cell {
  name = "hello"
  base = "alpine:3.19"

  env {
    GREETING = "Hello from inside the cell!"
  }

  fs {
    copy "testdata/" to "/app"
  }

  run = "/bin/sh -c 'echo $GREETING && cat /app/hello.txt'"
  expose = [8080]

  limits {
    memory = "256MB"
    processes = 10
  }
}
